# Copy this file to `.env` and fill in the credentials you have.
# The system runs without any of them, but specific data-collection
# subcommands need specific keys.

# Anthropic — used by `data_collection.py synth` to generate AI-ragebait
# training data via the Claude API. Free credits available at console.anthropic.com.
ANTHROPIC_API_KEY=

# Hugging Face — only required for gated datasets. Public datasets (HC3,
# civil_comments, wiki_toxic) work without a token.
HF_TOKEN=

# Reddit (optional) — for `data_collection.py reddit` to collect real
# news-comment-style text from r/news, r/worldnews, r/politics.
# Get credentials at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=stem-games-ragebait-detector/0.1
